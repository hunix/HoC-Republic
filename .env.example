# Copy this file to .env and fill in your own Twilio credentials.
# Do not commit real account identifiers, auth tokens, phone numbers, or local secrets.

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Must be a WhatsApp-enabled Twilio number, prefixed with whatsapp:
TWILIO_WHATSAPP_FROM=whatsapp:+15551234567
