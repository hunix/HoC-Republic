{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Typecheck: Gateway",
      "type": "shell",
      "command": "npx tsgo --noEmit",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Typecheck: hoc-ui",
      "type": "shell",
      "command": "npx tsgo --noEmit",
      "options": {
        "cwd": "${workspaceFolder}/hoc-ui"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Typecheck: Lit UI",
      "type": "shell",
      "command": "npx tsgo --noEmit",
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Typecheck: All Packages",
      "dependsOn": [
        "Typecheck: Gateway",
        "Typecheck: hoc-ui",
        "Typecheck: Lit UI"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: Unit",
      "type": "shell",
      "command": "npx vitest run --config vitest.unit.config.ts",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Test: Gateway",
      "type": "shell",
      "command": "npx vitest run --config vitest.gateway.config.ts",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build UI",
      "type": "shell",
      "command": "pnpm ui:build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint: oxlint",
      "type": "shell",
      "command": "npx oxlint",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Dev: Start All",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
