# ============================================================
#  HoC — Complete Environment Configuration Template
#  Copy what you need to your local HoC/OpenClaw environment file.
#  Then restart the gateway.
#
#  Keys marked [FREE] can be obtained at no cost.
#  Keys marked [REQUIRED] are needed for basic operation.
# ============================================================


# ============================================================
# AI INFERENCE — CLOUD LLMS
# ============================================================

# ── Google Gemini [FREE tier available, RECOMMENDED PRIMARY] ──
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash          # cheapest, best for citizen decisions

# ── OpenAI ──────────────────────────────────────────────────
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── NVIDIA NIM — Nemotron 3 Super 120B [FREE 40 RPM] ────────
# Get at: https://build.nvidia.com (free, no credit card)
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# ── Anthropic Claude ────────────────────────────────────────
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-3-5-20241022

# ── Groq [FREE tier, ultra-fast Llama 70B] ──────────────────
# Get at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── DeepSeek [ultra cheap, great coding] ────────────────────
# Get at: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── OpenRouter [100+ models, one key] ───────────────────────
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=auto

# ── Cloudflare AI Gateway [optional proxy/analytics] ────────
CLOUDFLARE_AI_GATEWAY_API_KEY=


# ============================================================
# LOCAL INFERENCE — LM STUDIO & OLLAMA
# ============================================================

# ── LM Studio ──────────────────────────────────────────────
LMSTUDIO_HOST=localhost
LMSTUDIO_PORT=1234
LMSTUDIO_MODEL=qwen3-30b-a3b-iq4_xs   # example local model; adjust to your hardware
LMSTUDIO_API_TOKEN=                    # leave blank if no auth set
LMSTUDIO_MAX_MODEL_SIZE=24000          # max VRAM MB to use; adjust for your machine
# Comma-separated additional LM Studio instances (for cluster)
LMSTUDIO_REMOTE_URLS=

# ── Ollama ───────────────────────────────────────────────────
OLLAMA_HOST=localhost
OLLAMA_MODEL=nemotron3-super
OLLAMA_API_KEY=                        # only if you added auth

# ── BitNet (local ultra-light model) ────────────────────────
BITNET_URL=http://localhost:8080


# ============================================================
# AGENT LOOP MODEL OVERRIDES
# ============================================================

# Override which model runs the main citizen decision loop
AGENT_LOOP_MODEL=gemini-2.5-flash
AGENT_LOOP_GEMINI_MODEL=gemini-2.5-flash
AGENT_LOOP_OPENAI_MODEL=gpt-4o-mini

# Cloud inference budget for citizen decisions
CITIZEN_CLOUD_INFERENCE=true
CITIZEN_CLOUD_MAX_HOURLY=500           # max cloud API calls/hour across all citizens


# ============================================================
# WEB SEARCH & SCRAPING
# ============================================================

# Brave Search API [FREE 2000 queries/month]
# Get at: https://brave.com/search/api/
BRAVE_API_KEY=

# Firecrawl — advanced web scraping
# Get at: https://www.firecrawl.dev
FIRECRAWL_API_KEY=

# Voyage AI — semantic embeddings for memory
# Get at: https://www.voyageai.com
VOYAGE_API_KEY=


# ============================================================
# IMAGE / AUDIO / VIDEO GENERATION
# ============================================================

# ElevenLabs — high quality TTS
# Get at: https://elevenlabs.io
ELEVENLABS_API_KEY=
XI_API_KEY=                            # alias used by some tools

# Suno — AI music generation
SUNO_API_KEY=

# Udio — alternative AI music
UDIO_API_KEY=

# ComfyUI (local Stable Diffusion)
COMFYUI_API_URL=http://localhost:8188
COMFYUI_MODELS_DIR=

# Stable Diffusion WebUI (local)
SD_API_URL=http://localhost:7860

# Bark TTS (local)
BARK_API_URL=http://localhost:8080

# AudioCraft (local)
AUDIOCRAFT_API_URL=http://localhost:8080

# Whisper.cpp (local ASR)
WHISPER_CPP_MODEL=


# ============================================================
# DATABASES & PERSISTENCE
# ============================================================

# Supabase — persistent republic DB (optional, in-memory works without)
# Get at: https://supabase.com (free tier available)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=             # alias
SUPABASE_DB_URL=                       # direct Postgres connection string


# ============================================================
# DEVTOOLS & CODE EXECUTION
# ============================================================

# GitHub — citizen CICD, code repos, PR automation
# Get at: https://github.com/settings/tokens
GITHUB_TOKEN=
GH_TOKEN=                              # alias, same token

# HuggingFace — model downloads
# Get at: https://huggingface.co/settings/tokens
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=               # alias, same token

# Vercel — frontend deployment
VERCEL_TOKEN=

# Netlify — alternative deployment
NETLIFY_AUTH_TOKEN=

# Claude Code CLI (web session)
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=

# Anthropic OAuth (for Claude Code)
ANTHROPIC_OAUTH_TOKEN=


# ============================================================
# AUTOMATION & INTEGRATIONS
# ============================================================

# n8n workflow automation
N8N_API_KEY=
N8N_BASE_URL=http://localhost:5678

# Composio — agent tool integrations
COMPOSIO_CONSUMER_KEY=

# GitHub Copilot token
COPILOT_GITHUB_TOKEN=


# ============================================================
# COMMUNICATION BOTS (optional)
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# LINE Messaging
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=


# ============================================================
# ECONOMY & PAYMENTS (optional)
# ============================================================

# Stripe — republic economy / payments
STRIPE_SECRET_KEY=

# OANDA — forex trading simulation
OANDA_API_KEY=


# ============================================================
# CLOUD PROVIDERS (optional)
# ============================================================

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEARER_TOKEN_BEDROCK=

# Minimax (Chinese LLM, multilingual)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat
MINIMAX_MODEL=

# Kimi (Moonshot AI)
MOONSHOT_API_KEY=
KIMI_API_KEY=

# Venice AI (private inference)
VENICE_API_KEY=

# Z AI
ZAI_API_KEY=
Z_AI_API_KEY=

# Chutes (decentralized inference)
CHUTES_CLIENT_SECRET=


# ============================================================
# GATEWAY & CLUSTERING
# ============================================================

# Gateway port (default 3000)
GATEWAY_PORT=3000
OPENCLAW_GATEWAY_PORT=3000

# Authentication
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
HOC_ADMIN_SECRET=                      # admin panel auth
HOC_REGISTER_SECRET=

# Republic master key (citizen data encryption)
REPUBLIC_MASTER_KEY=

# Republic MCP server port (for tool protocol)
REPUBLIC_MCP_PORT=

# Cluster / Redis
OPENCLAW_CLUSTER_ENABLED=false
OPENCLAW_REDIS_HOST=localhost
OPENCLAW_REDIS_PORT=6379
OPENCLAW_REDIS_PASSWORD=

# LM Link (remote LM Studio instances)
LMLINK_RTX6000_HOST=
LMLINK_RTX6000_PORT=
LMLINK_RTX6000_TOKEN=


# ============================================================
# DIRECTORY PATHS (usually auto-detected)
# ============================================================

# Override the gateway state/config directory
# Default: platform-specific user configuration directory, for example ~/.openclaw
OPENCLAW_STATE_DIR=

# Plugin directories (auto-detected from repo)
HOC_PLUGINS_DIR=
HOC_PLUGIN_DATA_DIR=
