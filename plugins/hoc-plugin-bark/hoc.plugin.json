{
  "id": "hoc-plugin-bark",
  "name": "Bark — Text-to-Audio Generation",
  "version": "1.0.0",
  "displayName": "Bark TTS (Suno AI)",
  "description": "State-of-the-art text-to-audio. Generates speech, music, sound effects, and nonverbal audio using suno-ai/bark. Supports 100+ voice presets, 13 languages, and paralinguistic markup ([laughs], ♪, etc.).",
  "sourceRepo": "https://github.com/suno-ai/bark",
  "author": "HoC Republic",

  "backend": {
    "type": "python-cli",
    "repo": "https://github.com/suno-ai/bark.git",
    "deps": ["bark", "scipy"],
    "verifyImport": "from bark import generate_audio, SAMPLE_RATE"
  },

  "toolDefinitions": [
    {
      "name": "bark_generate",
      "description": "Generate audio from text — speech, music (♪), sound effects, nonverbal [laughs]. Supports 100+ voice presets and 13 languages.",
      "params": {
        "text": {
          "type": "string",
          "description": "Text prompt with optional markup ([laughs], ♪, etc.)",
          "required": true
        },
        "voice_preset": {
          "type": "string",
          "description": "Voice preset ID (e.g., 'v2/en_speaker_1')"
        },
        "mode": {
          "type": "string",
          "enum": ["speech", "music", "sound-effect", "mixed"],
          "description": "Audio mode"
        },
        "text_temp": {
          "type": "number",
          "description": "Text generation temperature (default: 0.7)"
        },
        "waveform_temp": {
          "type": "number",
          "description": "Waveform generation temperature (default: 0.7)"
        }
      },
      "command": "bark_generate"
    }
  ],

  "gatewayDefinitions": [
    { "method": "bark.generate", "delegateTo": "bark_generate" },
    { "method": "bark.job-status", "delegateTo": "_job_status" },
    { "method": "bark.cancel", "delegateTo": "_cancel" },
    { "method": "bark.queue-status", "delegateTo": "_queue_status" }
  ],

  "jobQueue": {
    "maxConcurrent": 1,
    "timeoutMs": 300000
  },

  "capabilities": {
    "tools": ["bark_generate", "bark_job_status", "bark_cancel", "bark_queue_status"],
    "hooks": ["tick:before"]
  },

  "requirements": {
    "binaries": ["python3"]
  },

  "bootPriority": 50
}
