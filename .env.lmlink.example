# HoC / OpenClaw LM Link example configuration
#
# Copy relevant lines to your local environment file and replace all placeholder
# hosts, ports, labels, and tokens with values from your own inference fleet.
# The gateway auto-registers the local LM Studio instance on every boot.

# Example fleet layout:
#   Device 1 — Local workstation, auto-registered by the gateway
#   Device 2 — Remote workstation, reachable over a private network or VPN
#   Device 3 — High-memory inference server, reachable over a private network or VPN

# ─── Device 1: Local LM Studio instance ───────────────────────────────────────
# Customize the label shown in the LM Link dashboard.
# LMLINK_LOCAL_LABEL=Local LM Studio
#
# Model recommendation for a 24 GB-class GPU. Adjust for your hardware.
LMSTUDIO_MODEL=qwen3-30b-a3b-iq4_xs
LMSTUDIO_PORT=1234

# ─── Device 2: Remote workstation example ────────────────────────────────────
# Set LMLINK_WORKSTATION_HOST to the private IP address or hostname of the node.
# Model recommendation: use a model that fits the node's VRAM and latency budget.
LMLINK_WORKSTATION_HOST=<private-ip-or-hostname>
LMLINK_WORKSTATION_PORT=1234
LMLINK_WORKSTATION_LABEL=Remote Workstation
# LMLINK_WORKSTATION_TOKEN=       # Uncomment if LM Studio auth is enabled
# LMLINK_WORKSTATION_DOCKER_URL=tcp://<private-ip-or-hostname>:2375 # Optional remote Docker endpoint

# ─── Device 3: High-memory inference server example ──────────────────────────
# Set LMLINK_SERVER_HOST to the private IP address or hostname of the server.
# Model recommendation: use larger mixture-of-experts or long-context models only
# when the server has enough memory and cooling capacity.
LMLINK_SERVER_HOST=<private-ip-or-hostname>
LMLINK_SERVER_PORT=1234
LMLINK_SERVER_LABEL=High-Memory Inference Server
# LMLINK_SERVER_TOKEN=        # Uncomment if LM Studio auth is enabled
# LMLINK_SERVER_DOCKER_URL=tcp://<private-ip-or-hostname>:2375 # Optional remote Docker endpoint

# ─── Additional Nodes (optional) ──────────────────────────────────────────────
# Add more nodes with the generic numbered scheme:
# LMLINK_NODE1_HOST=<private-ip-or-hostname>
# LMLINK_NODE1_PORT=1234
# LMLINK_NODE1_LABEL=Extra Node 1
# LMLINK_NODE1_GPU=rtx-4090-24gb   # Key from LM_LINK_GPU_PROFILES
# LMLINK_NODE1_POWER=false          # Set true to prefer this node for complex tasks
# LMLINK_NODE1_TOKEN=               # Optional API token
# LMLINK_NODE1_DOCKER_URL=tcp://<private-ip-or-hostname>:2375 # Optional Docker daemon endpoint
#
# Or add multiple nodes as a comma-separated string:
# LMLINK_EXTRA_NODES=label@host:port:token:dockerUrl,label2@...

# ─── Routing Policy ──────────────────────────────────────────────────────────
# LMLINK_ROUTING_STRATEGY defaults to "auto" (latency + tier-aware selection).
# Set to "manual" and LMLINK_PREFERRED_NODE to pin inference to one node.
# LMLINK_ROUTING_STRATEGY=auto          # auto | manual
# LMLINK_PREFERRED_NODE=lmlink-<ip>:1234  # Only used with strategy=manual

# ─── Local GPU Profile Override ──────────────────────────────────────────────
# Force a specific hardware profile for the local LM Studio instance.
# Leave unset for auto-detection from nvidia-smi / hardware-manager.
# GPU_PROFILE=rtx-4090-24gb             # override auto-detect
# Local context override (defaults to the selected profile value)
# LOCAL_MAX_CONTEXT=16384
